<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Root menu -->
  <menuitem id="menu_gulmi_root"
            name="Gulmi Coffee"
            web_icon="gulmi_coffee,static/description/icon.png"
            sequence="10"/>

  <!-- Value Chain -->
  <menuitem id="menu_value_chain"
            name="Value Chain"
            parent="menu_gulmi_root"
            sequence="10"/>
  <menuitem id="menu_coffee_stages"
            name="Processing Stages"
            parent="menu_value_chain"
            action="action_coffee_stages"
            sequence="10"/>
  <menuitem id="menu_coffee_costing"
            name="Costing by Source"
            parent="menu_value_chain"
            action="action_coffee_costing"
            sequence="20"/>

  <!-- Finance shortcuts -->
  <menuitem id="menu_gulmi_finance"
            name="Finance"
            parent="menu_gulmi_root"
            sequence="40"/>
  <menuitem id="menu_gulmi_invoices"
            name="Customer Invoices"
            parent="menu_gulmi_finance"
            action="account.action_move_out_invoice_type"
            sequence="10"/>
  <menuitem id="menu_gulmi_vendor_bills"
            name="Vendor Bills"
            parent="menu_gulmi_finance"
            action="account.action_move_in_invoice_type"
            sequence="20"/>
</odoo>
